{
  "name": "seviye-ts-starter-kit",
  "version": "1.0.0",
  "description": "A clean, production-ready Express and TypeScript boilerplate for scalable APIs",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node src/app.ts",
